# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored and must never be committed.

# A unique, secret key used by Django for cryptographic signing.
# Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-change-me

# Must be False in production.
DEBUG=True

# Comma-separated list of hostnames this server is allowed to serve.
# Local development:
ALLOWED_HOSTS=127.0.0.1,localhost
# Production example:
# ALLOWED_HOSTS=coderr.marc-schaar.com

# Comma-separated list of trusted origins (scheme + host) for unsafe
# requests (e.g. the Django admin login). Only needed when DEBUG=False.
# CSRF_TRUSTED_ORIGINS=https://coderr.marc-schaar.com

# Number of gunicorn worker processes (production/Docker only).
# GUNICORN_WORKERS=3

# --- Database ---
# Only used when DEBUG=False. With DEBUG=True the app always uses a local
# SQLite file (db.sqlite3) and these variables are ignored.
DB_NAME=coderr
DB_USER=coderr
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432
